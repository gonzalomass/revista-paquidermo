---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getAuthorMap, getAuthorName } from '../../lib/authors';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const categoryMap = new Map<string, { name: string; slug: string; posts: any[] }>();

  for (const post of posts) {
    for (const cat of post.data.categories) {
      const slug = cat.toLowerCase().replace(/\s+/g, '-');
      if (!categoryMap.has(slug)) {
        categoryMap.set(slug, { name: cat, slug, posts: [] });
      }
      categoryMap.get(slug)!.posts.push(post);
    }
  }

  return Array.from(categoryMap.values()).map((cat) => ({
    params: { slug: cat.slug },
    props: {
      name: cat.name,
      posts: cat.posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { name, posts } = Astro.props;
const authorMap = await getAuthorMap();
---

<BaseLayout title={name}>
  <header class="mb-12 pb-8 border-b border-paqui-rule" data-pagefind-filter="tipo:Categorías">
    <p class="text-[11px] font-sans font-semibold uppercase tracking-[0.15em] text-paqui-red mb-3">Categoría</p>
    <h1 class="font-display text-3xl md:text-5xl font-bold text-paqui-dark">{name}</h1>
    <p class="mt-3 text-sm font-sans text-paqui-muted">{posts.length} artículos</p>
  </header>

  <div class="grid md:grid-cols-2 gap-x-16">
    {posts.map((post: any) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        author={post.data.author}
        authorName={getAuthorName(authorMap, post.data.author)}
        slug={post.data.slug}
        excerpt={post.data.excerpt}
        categories={post.data.categories}
      />
    ))}
  </div>
</BaseLayout>
