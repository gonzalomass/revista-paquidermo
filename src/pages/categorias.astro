---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const categoryMap = new Map<string, { name: string; slug: string; count: number }>();

for (const post of posts) {
  for (const cat of post.data.categories) {
    const slug = cat.toLowerCase().replace(/\s+/g, '-');
    if (!categoryMap.has(slug)) {
      categoryMap.set(slug, { name: cat, slug, count: 0 });
    }
    categoryMap.get(slug)!.count++;
  }
}

const categories = Array.from(categoryMap.values()).sort((a, b) => b.count - a.count);
---

<BaseLayout title="Categorías" noindex>
  <header class="mb-10">
    <h1 class="font-display text-3xl md:text-4xl font-bold text-paqui-dark">Categorías</h1>
    <p class="mt-2 text-sm font-sans text-paqui-muted">{categories.length} temas explorados</p>
  </header>

  <input
    type="text"
    id="filter"
    placeholder="Buscar categoría..."
    class="w-full border-b border-paqui-rule bg-transparent px-0 py-3 text-sm font-sans text-paqui-body focus:outline-none focus:border-paqui-red placeholder:text-paqui-muted transition-colors mb-10"
  />

  <div id="list" class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8">
    {categories.map((cat) => (
      <a
        href={`/categoria/${cat.slug}`}
        data-name={cat.name.toLowerCase()}
        class="filter-item flex justify-between items-baseline py-3 border-b border-paqui-rule/40 hover:text-paqui-red transition-colors group"
      >
        <span class="font-serif font-semibold group-hover:text-paqui-red transition-colors">{cat.name}</span>
        <span class="text-xs font-sans text-paqui-muted ml-2 shrink-0">{cat.count}</span>
      </a>
    ))}
  </div>

  <p id="no-results" class="hidden text-paqui-muted text-sm font-sans mt-6">No se encontraron categorías.</p>
</BaseLayout>

<script is:inline>
  document.getElementById('filter').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    var items = document.querySelectorAll('.filter-item');
    var visible = 0;
    items.forEach(function (el) {
      var match = el.getAttribute('data-name').indexOf(q) !== -1;
      el.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    document.getElementById('no-results').style.display = visible ? 'none' : 'block';
  });
</script>
