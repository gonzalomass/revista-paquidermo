---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  const posts = await getCollection('posts');

  return authors.map((author) => {
    const authorPosts = posts
      .filter((p) => p.data.author === author.data.slug)
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
    return {
      params: { slug: author.data.slug },
      props: { author, posts: authorPosts },
    };
  });
}

const { author, posts } = Astro.props;
---

<BaseLayout title={author.data.name}>
  <header class="mb-12 pb-8 border-b border-paqui-rule" data-pagefind-filter="tipo:Autores">
    <p class="text-[11px] font-sans font-semibold uppercase tracking-[0.15em] text-paqui-red mb-3">Autor</p>
    <h1 class="font-display text-3xl md:text-5xl font-bold text-paqui-dark">{author.data.name}</h1>
    <p class="mt-3 text-sm font-sans text-paqui-muted">
      {posts.length} {posts.length === 1 ? 'artículo publicado' : 'artículos publicados'}
    </p>
  </header>

  <div class="grid md:grid-cols-2 gap-x-16">
    {posts.map((post: any) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        author={post.data.author}
        authorName={author.data.name}
        slug={post.data.slug}
        excerpt={post.data.excerpt}
        categories={post.data.categories}
      />
    ))}
  </div>
</BaseLayout>
