---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getAuthorMap, getAuthorName } from '../../lib/authors';
import { slugify } from '../../lib/slugify';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const columnaMap = new Map<string, { name: string; slug: string; posts: any[] }>();

  for (const post of posts) {
    if (!post.data.columna) continue;
    const name = post.data.columna;
    const slug = name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    if (!columnaMap.has(slug)) {
      columnaMap.set(slug, { name, slug, posts: [] });
    }
    columnaMap.get(slug)!.posts.push(post);
  }

  return Array.from(columnaMap.values()).map((col) => ({
    params: { slug: col.slug },
    props: {
      name: col.name,
      posts: col.posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { name, posts } = Astro.props;
const authorMap = await getAuthorMap();
---

<BaseLayout title={`Columna: ${name}`}>
  <header class="mb-12 pb-8 border-b border-paqui-rule">
    <p class="text-[11px] font-sans font-semibold uppercase tracking-[0.15em] text-paqui-red mb-3">Columna</p>
    <h1 class="font-display text-3xl md:text-5xl font-bold text-paqui-dark">{name}</h1>
    <p class="mt-3 text-sm font-sans text-paqui-muted">{posts.length} artículos</p>
  </header>

  <div class="grid md:grid-cols-2 gap-x-16">
    {posts.map((post: any) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        author={post.data.author}
        authorName={getAuthorName(authorMap, post.data.author)}
        slug={post.data.slug}
        excerpt={post.data.excerpt}
        categories={post.data.categories}
        columna={post.data.columna}
        seccion={post.data.seccion}
      />
    ))}
  </div>
</BaseLayout>
