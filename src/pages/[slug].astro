---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getAuthorMap, getAuthorName } from '../lib/authors';
import { slugify } from '../lib/slugify';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const authorMap = await getAuthorMap();
const authorDisplayName = getAuthorName(authorMap, post.data.author);

const dateObj = new Date(post.data.date);
const formattedDate = dateObj.toLocaleDateString('es-CR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <article class="max-w-3xl mx-auto" data-pagefind-filter="tipo:Artículos">
    <header class="mb-10">
      {post.data.categories.length > 0 && (
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-4">
          <svg class="w-3.5 h-3.5 text-paqui-red shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="5" height="5" rx="0.5"/><rect x="9" y="2" width="5" height="5" rx="0.5"/><rect x="2" y="9" width="5" height="5" rx="0.5"/><rect x="9" y="9" width="5" height="5" rx="0.5"/></svg>
          {post.data.categories.map((cat: string) => (
            <a
              href={`/categoria/${cat.toLowerCase().replace(/\s+/g, '-')}`}
              class="text-[11px] font-sans font-bold uppercase tracking-[0.15em] text-paqui-red hover:text-paqui-dark transition-colors"
            >
              - {cat} -
            </a>
          ))}
        </div>
      )}

      <h1 class="font-display text-3xl md:text-5xl font-bold leading-[1.1] text-paqui-dark">
        {post.data.title}
      </h1>

      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-sans text-paqui-gray">
        {post.data.author && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-paqui-red shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.5 14v-1.5a2.5 2.5 0 00-2.5-2.5H6a2.5 2.5 0 00-2.5 2.5V14"/><circle cx="8" cy="5" r="2.5"/></svg>
            <a href={`/autor/${post.data.author}`} class="font-bold text-paqui-body text-paqui-red hover:text-paqui-dark transition-colors">
              {authorDisplayName}
            </a>
          </span>
        )}
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="12" height="12" rx="1"/><path d="M2 6h12M5 2v4M11 2v4"/></svg>
          <time datetime={post.data.date} class="text-paqui-muted">{formattedDate}</time>
        </span>
        {post.data.columna && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v12M8 2v12M13 2v12"/></svg>
            <a href={`/columna/${slugify(post.data.columna)}`} class="text-paqui-gray hover:text-paqui-red transition-colors">{post.data.columna}</a>
          </span>
        )}
        {post.data.seccion && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4h12M2 8h12M2 12h12"/></svg>
            <a href={`/seccion/${slugify(post.data.seccion)}`} class="text-paqui-gray hover:text-paqui-red transition-colors">{post.data.seccion}</a>
          </span>
        )}
      </div>

      <div class="mt-8 w-16 h-[2px] bg-paqui-red"></div>
    </header>

    <div class="prose prose-xl max-w-none drop-cap">
      <Content />
    </div>

    {post.data.tags.length > 0 && (
      <footer class="mt-14 pt-8 border-t border-paqui-rule">
        <div class="flex flex-wrap gap-2 items-center">
          <svg class="w-3.5 h-3.5 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 8.5l-5 5-6-6V2.5h5l6 6z"/><circle cx="5.5" cy="5.5" r="1"/></svg>
          <span class="text-[11px] font-sans font-medium uppercase tracking-wider text-paqui-muted mr-1">Etiquetas</span>
          {post.data.tags.map((tag: string) => (
            <a href={`/etiqueta/${slugify(tag)}`} class="text-xs font-sans text-paqui-gray bg-paqui-warm px-2.5 py-1 hover:text-paqui-red hover:bg-paqui-warm/80 transition-colors">{tag}</a>
          ))}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>
