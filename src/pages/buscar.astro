---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Buscar" noindex>
  <header class="mb-8">
    <h1 class="font-display text-3xl md:text-4xl font-bold text-paqui-dark">Buscar</h1>
  </header>

  <div class="flex flex-wrap gap-2 mb-6" id="filters">
    <button data-filter="" class="filter-btn active text-[10px] font-sans font-semibold uppercase tracking-[0.15em] px-3 py-1.5 border bg-paqui-dark border-paqui-dark text-white transition-colors">Todo</button>
    <button data-filter="Artículos" class="filter-btn text-[10px] font-sans font-semibold uppercase tracking-[0.15em] px-3 py-1.5 border border-paqui-rule text-paqui-gray hover:border-paqui-dark hover:text-paqui-dark transition-colors">Artículos</button>
    <button data-filter="Autores" class="filter-btn text-[10px] font-sans font-semibold uppercase tracking-[0.15em] px-3 py-1.5 border border-paqui-rule text-paqui-gray hover:border-paqui-dark hover:text-paqui-dark transition-colors">Autores</button>
    <button data-filter="Categorías" class="filter-btn text-[10px] font-sans font-semibold uppercase tracking-[0.15em] px-3 py-1.5 border border-paqui-rule text-paqui-gray hover:border-paqui-dark hover:text-paqui-dark transition-colors">Categorías</button>
  </div>

  <input
    type="text"
    id="search-input"
    placeholder="lo que le salga de las narices buscar..."
    class="w-full border-b-2 border-paqui-dark bg-transparent px-0 py-3 text-lg font-serif text-paqui-body focus:outline-none focus:border-paqui-red placeholder:text-paqui-muted/50 placeholder:italic transition-colors"
    autofocus
  />

  <div id="results" class="mt-8"></div>
  <p id="no-results" class="hidden text-paqui-muted text-sm font-sans mt-8">No se encontraron resultados.</p>
  <p id="status" class="text-paqui-muted text-xs font-sans mt-4"></p>
</BaseLayout>

<script is:inline type="module">
  var pagefind = null;
  var currentFilter = '';
  var debounceTimer = null;

  try {
    pagefind = await import('/pagefind/pagefind.js');
  } catch (e) {
    console.warn('Pagefind not available — run npm run build first');
    document.getElementById('status').textContent = 'Índice de búsqueda no disponible. Ejecute npm run build.';
  }

  document.querySelectorAll('.filter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.filter-btn').forEach(function (b) {
        b.classList.remove('active', 'bg-paqui-dark', 'text-white', 'border-paqui-dark');
        b.classList.add('border-paqui-rule', 'text-paqui-gray');
      });
      btn.classList.add('active', 'bg-paqui-dark', 'text-white', 'border-paqui-dark');
      btn.classList.remove('border-paqui-rule', 'text-paqui-gray');
      currentFilter = btn.getAttribute('data-filter');
      doSearch();
    });
  });

  document.getElementById('search-input').addEventListener('input', function () {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doSearch, 200);
  });

  async function doSearch() {
    if (!pagefind) return;

    var query = document.getElementById('search-input').value.trim();
    var resultsEl = document.getElementById('results');
    var noResultsEl = document.getElementById('no-results');
    var statusEl = document.getElementById('status');

    if (!query) {
      resultsEl.innerHTML = '';
      noResultsEl.style.display = 'none';
      statusEl.textContent = '';
      return;
    }

    var opts = {};
    if (currentFilter) {
      opts.filters = { tipo: [currentFilter] };
    }

    var search = await pagefind.search(query, opts);

    if (search.results.length === 0) {
      resultsEl.innerHTML = '';
      noResultsEl.style.display = 'block';
      statusEl.textContent = '';
      return;
    }

    noResultsEl.style.display = 'none';
    var total = search.results.length;
    var show = Math.min(total, 30);
    statusEl.textContent = total + ' resultado' + (total !== 1 ? 's' : '') + (total > 30 ? ' (mostrando 30)' : '');

    var results = await Promise.all(search.results.slice(0, show).map(function (r) { return r.data(); }));

    resultsEl.innerHTML = '';
    results.forEach(function (r) {
      var a = document.createElement('a');
      a.href = r.url;
      a.className = 'search-result';

      var header = document.createElement('div');
      header.style.display = 'flex';
      header.style.alignItems = 'center';
      header.style.flexWrap = 'wrap';
      header.style.gap = '2px';

      if (r.filters && r.filters.tipo) {
        var tipo = r.filters.tipo[0];
        if (tipo === 'Autores' || tipo === 'Categorías') {
          var badge = document.createElement('span');
          badge.className = 'search-result-badge ' + (tipo === 'Autores' ? 'search-result-badge--author' : 'search-result-badge--category');
          badge.textContent = tipo === 'Autores' ? 'Autor' : 'Categoría';
          header.appendChild(badge);
        }
      }

      var title = document.createElement('span');
      title.className = 'search-result-title';
      title.textContent = r.meta.title;
      header.appendChild(title);
      a.appendChild(header);

      if (r.excerpt) {
        var p = document.createElement('p');
        p.className = 'search-result-excerpt';
        p.innerHTML = r.excerpt;
        a.appendChild(p);
      }

      resultsEl.appendChild(a);
    });
  }
</script>
