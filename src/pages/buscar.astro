---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Buscar" noindex>
  <h1 class="font-display text-2xl md:text-4xl font-bold mb-4 md:mb-6">Buscar</h1>

  <div class="flex flex-wrap gap-2 mb-4" id="filters">
    <button data-filter="" class="filter-btn active px-3 py-1.5 text-xs md:text-sm font-medium uppercase tracking-wider border border-paqui-red bg-paqui-red text-white transition-colors">Todo</button>
    <button data-filter="Artículos" class="filter-btn px-3 py-1.5 text-xs md:text-sm font-medium uppercase tracking-wider border border-gray-300 text-paqui-gray hover:border-paqui-red hover:text-paqui-red transition-colors">Artículos</button>
    <button data-filter="Autores" class="filter-btn px-3 py-1.5 text-xs md:text-sm font-medium uppercase tracking-wider border border-gray-300 text-paqui-gray hover:border-paqui-red hover:text-paqui-red transition-colors">Autores</button>
    <button data-filter="Categorías" class="filter-btn px-3 py-1.5 text-xs md:text-sm font-medium uppercase tracking-wider border border-gray-300 text-paqui-gray hover:border-paqui-red hover:text-paqui-red transition-colors">Categorías</button>
  </div>

  <input
    type="text"
    id="search-input"
    placeholder="lo que le salga de las narices buscar..."
    class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-paqui-red"
    autofocus
  />

  <div id="results" class="mt-6"></div>
  <p id="no-results" class="hidden text-paqui-gray text-sm mt-6">No se encontraron resultados.</p>
  <p id="status" class="text-paqui-gray text-xs mt-4"></p>
</BaseLayout>

<script is:inline type="module">
  var pagefind = null;
  var currentFilter = '';
  var debounceTimer = null;

  try {
    pagefind = await import('/pagefind/pagefind.js');
  } catch (e) {
    console.warn('Pagefind not available — run npm run build first');
    document.getElementById('status').textContent = 'Índice de búsqueda no disponible. Ejecute npm run build.';
  }

  // Filter buttons
  document.querySelectorAll('.filter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.filter-btn').forEach(function (b) {
        b.classList.remove('active', 'bg-paqui-red', 'text-white', 'border-paqui-red');
        b.classList.add('border-gray-300', 'text-paqui-gray');
      });
      btn.classList.add('active', 'bg-paqui-red', 'text-white', 'border-paqui-red');
      btn.classList.remove('border-gray-300', 'text-paqui-gray');
      currentFilter = btn.getAttribute('data-filter');
      doSearch();
    });
  });

  // Search input
  document.getElementById('search-input').addEventListener('input', function () {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doSearch, 200);
  });

  async function doSearch() {
    if (!pagefind) return;

    var query = document.getElementById('search-input').value.trim();
    var resultsEl = document.getElementById('results');
    var noResultsEl = document.getElementById('no-results');
    var statusEl = document.getElementById('status');

    if (!query) {
      resultsEl.innerHTML = '';
      noResultsEl.style.display = 'none';
      statusEl.textContent = '';
      return;
    }

    var opts = {};
    if (currentFilter) {
      opts.filters = { tipo: [currentFilter] };
    }

    var search = await pagefind.search(query, opts);

    if (search.results.length === 0) {
      resultsEl.innerHTML = '';
      noResultsEl.style.display = 'block';
      statusEl.textContent = '';
      return;
    }

    noResultsEl.style.display = 'none';
    var total = search.results.length;
    var show = Math.min(total, 30);
    statusEl.textContent = total + ' resultado' + (total !== 1 ? 's' : '') + (total > 30 ? ' (mostrando 30)' : '');

    var results = await Promise.all(search.results.slice(0, show).map(function (r) { return r.data(); }));

    resultsEl.innerHTML = '';
    results.forEach(function (r) {
      var a = document.createElement('a');
      a.href = r.url;
      a.className = 'block border-l-4 border-transparent hover:border-paqui-red pl-4 py-3 transition-all';

      var header = document.createElement('div');
      header.className = 'flex items-center flex-wrap gap-1';

      if (r.filters && r.filters.tipo) {
        var tipo = r.filters.tipo[0];
        if (tipo === 'Autores' || tipo === 'Categorías') {
          var badge = document.createElement('span');
          badge.className = 'text-xs font-semibold uppercase tracking-wider text-white px-2 py-0.5 mr-2 inline-block ' + (tipo === 'Autores' ? 'bg-paqui-dark' : 'bg-paqui-gray');
          badge.textContent = tipo === 'Autores' ? 'Autor' : 'Categoría';
          header.appendChild(badge);
        }
      }

      var title = document.createElement('span');
      title.className = 'font-display text-base md:text-lg font-bold';
      title.textContent = r.meta.title;
      header.appendChild(title);
      a.appendChild(header);

      if (r.excerpt) {
        var p = document.createElement('p');
        p.className = 'text-sm text-paqui-gray mt-1';
        p.innerHTML = r.excerpt; // Pagefind excerpts contain <mark> tags for highlighting
        a.appendChild(p);
      }

      resultsEl.appendChild(a);
    });
  }
</script>

<style>
  :global(mark) {
    background-color: #fef3c7;
    font-weight: 600;
    color: inherit;
  }
</style>
