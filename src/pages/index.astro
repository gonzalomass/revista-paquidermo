---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getAuthorMap, getAuthorName } from '../lib/authors';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const authorMap = await getAuthorMap();

const postsPerPage = 12;
const totalPages = Math.ceil(posts.length / postsPerPage);
const currentPosts = posts.slice(0, postsPerPage);

const heroPost = currentPosts[0];
const heroAuthorName = getAuthorName(authorMap, heroPost.data.author);
const heroDate = new Date(heroPost.data.date).toLocaleDateString('es-CR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout noindex>
  <article class="mb-10 pb-10 border-b border-paqui-rule group">
    {heroPost.data.categories.length > 0 && (
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
        <svg class="w-3.5 h-3.5 text-paqui-red shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="5" height="5" rx="0.5"/><rect x="9" y="2" width="5" height="5" rx="0.5"/><rect x="2" y="9" width="5" height="5" rx="0.5"/><rect x="9" y="9" width="5" height="5" rx="0.5"/></svg>
        {heroPost.data.categories.map((cat: string) => (
          <a
            href={`/categoria/${cat.toLowerCase().replace(/\s+/g, '-')}`}
            class="text-[11px] font-sans font-bold uppercase tracking-[0.15em] text-paqui-red hover:text-paqui-dark transition-colors"
          >
            - {cat} -
          </a>
        ))}
      </div>
    )}

    <a href={`/${heroPost.data.slug}`} class="block">
      <h2 class="font-display text-3xl md:text-5xl font-bold leading-[1.1] text-paqui-dark group-hover:text-paqui-red transition-colors duration-300">
        {heroPost.data.title}
      </h2>
    </a>

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-sans">
      {heroPost.data.author && (
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-paqui-red shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.5 14v-1.5a2.5 2.5 0 00-2.5-2.5H6a2.5 2.5 0 00-2.5 2.5V14"/><circle cx="8" cy="5" r="2.5"/></svg>
          <a href={`/autor/${heroPost.data.author}`} class="text-paqui-body font-bold text-paqui-red hover:text-paqui-dark transition-colors">
            {heroAuthorName}
          </a>
        </span>
      )}
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-4 h-4 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="12" height="12" rx="1"/><path d="M2 6h12M5 2v4M11 2v4"/></svg>
        <time datetime={heroPost.data.date} class="text-paqui-muted">{heroDate}</time>
      </span>
    </div>

    {heroPost.data.excerpt && (
      <p class="mt-5 text-lg md:text-xl font-serif text-paqui-black leading-relaxed max-w-3xl">
        {heroPost.data.excerpt}
        <a href={`/${heroPost.data.slug}`} class="text-paqui-red text-md md:text-lg font-sans tracking-wide hover:underline ml-1 whitespace-nowrap">
          ... la hablada &rarr;
        </a>
      </p>
    )}
  </article>

  <div class="grid md:grid-cols-2 gap-x-16">
    {currentPosts.slice(1).map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        author={post.data.author}
        authorName={getAuthorName(authorMap, post.data.author)}
        slug={post.data.slug}
        excerpt={post.data.excerpt}
        categories={post.data.categories}
        columna={post.data.columna}
        seccion={post.data.seccion}
      />
    ))}
  </div>

  <Pagination currentPage={1} totalPages={totalPages} />
</BaseLayout>
