---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getAuthorMap, getAuthorName } from '../lib/authors';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const authorMap = await getAuthorMap();

const postsPerPage = 12;
const totalPages = Math.ceil(posts.length / postsPerPage);
const currentPosts = posts.slice(0, postsPerPage);
---

<BaseLayout noindex>
  <div class="grid md:grid-cols-2 gap-x-12 gap-y-6 md:gap-y-10">
    {currentPosts.map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        author={post.data.author}
        authorName={getAuthorName(authorMap, post.data.author)}
        slug={post.data.slug}
        excerpt={post.data.excerpt}
        categories={post.data.categories}
      />
    ))}
  </div>

  <Pagination currentPage={1} totalPages={totalPages} />
</BaseLayout>
