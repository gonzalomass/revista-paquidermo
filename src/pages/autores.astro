---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const authors = await getCollection('authors');
const posts = await getCollection('posts');

const authorsWithCount = authors
  .map((a) => ({
    ...a,
    postCount: posts.filter((p) => p.data.author === a.data.slug).length,
  }))
  .sort((a, b) => b.postCount - a.postCount);
---

<BaseLayout title="Autores" noindex>
  <header class="mb-10">
    <h1 class="font-display text-3xl md:text-4xl font-bold text-paqui-dark">Autores</h1>
    <p class="mt-2 text-sm font-sans text-paqui-muted">{authorsWithCount.length} voces en el archivo</p>
  </header>

  <input
    type="text"
    id="filter"
    placeholder="Buscar autor..."
    class="w-full border-b border-paqui-rule bg-transparent px-0 py-3 text-sm font-sans text-paqui-body focus:outline-none focus:border-paqui-red placeholder:text-paqui-muted transition-colors mb-10"
  />

  <div id="list" class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8">
    {authorsWithCount.map((author) => (
      <a
        href={`/autor/${author.data.slug}`}
        data-name={author.data.name.toLowerCase()}
        class="filter-item flex justify-between items-baseline py-3 border-b border-paqui-rule/40 hover:text-paqui-red transition-colors group"
      >
        <span class="font-display text-lg font-semibold group-hover:text-paqui-red transition-colors">{author.data.name}</span>
        <span class="text-xs font-sans text-paqui-muted ml-2 shrink-0">{author.postCount}</span>
      </a>
    ))}
  </div>

  <p id="no-results" class="hidden text-paqui-muted text-sm font-sans mt-6">No se encontraron autores.</p>
</BaseLayout>

<script is:inline>
  document.getElementById('filter').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    var items = document.querySelectorAll('.filter-item');
    var visible = 0;
    items.forEach(function (el) {
      var match = el.getAttribute('data-name').indexOf(q) !== -1;
      el.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    document.getElementById('no-results').style.display = visible ? 'none' : 'block';
  });
</script>
