---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const authors = await getCollection('authors');
const posts = await getCollection('posts');

const authorsWithCount = authors
  .map((a) => ({
    ...a,
    postCount: posts.filter((p) => p.data.author === a.data.slug).length,
  }))
  .sort((a, b) => b.postCount - a.postCount);
---

<BaseLayout title="Autores" noindex>
  <h1 class="font-display text-2xl md:text-4xl font-bold mb-4 md:mb-6">Autores</h1>

  <input
    type="text"
    id="filter"
    placeholder="Filtrar autores..."
    class="w-full border border-gray-300 px-4 py-2 mb-6 text-sm focus:outline-none focus:border-paqui-red"
  />

  <div id="list" class="grid md:grid-cols-3 gap-4 md:gap-6">
    {authorsWithCount.map((author) => (
      <a
        href={`/autor/${author.data.slug}`}
        data-name={author.data.name.toLowerCase()}
        class="filter-item border border-gray-200 p-4 md:p-5 hover:border-paqui-red transition-colors group"
      >
        <h2 class="font-display text-lg font-bold group-hover:text-paqui-red transition-colors">
          {author.data.name}
        </h2>
        <p class="text-sm text-paqui-gray mt-1">
          {author.postCount} {author.postCount === 1 ? 'artículo' : 'artículos'}
        </p>
      </a>
    ))}
  </div>

  <p id="no-results" class="hidden text-paqui-gray text-sm mt-4">No se encontraron autores.</p>
</BaseLayout>

<script is:inline>
  document.getElementById('filter').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    var items = document.querySelectorAll('.filter-item');
    var visible = 0;
    items.forEach(function (el) {
      var match = el.getAttribute('data-name').indexOf(q) !== -1;
      el.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    document.getElementById('no-results').style.display = visible ? 'none' : 'block';
  });
</script>
