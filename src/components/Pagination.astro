---
interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;
const prevUrl = currentPage === 2 ? '/' : currentPage > 2 ? `/pagina/${currentPage - 1}` : null;
const nextUrl = currentPage < totalPages ? `/pagina/${currentPage + 1}` : null;
---

<nav class="flex justify-center items-center gap-8 mt-14 pt-8 border-t border-paqui-rule" aria-label="Paginación">
  {prevUrl ? (
    <a href={prevUrl} class="text-sm font-sans font-medium text-paqui-body hover:text-paqui-red transition-colors">
      &larr; Anterior
    </a>
  ) : (
    <span class="text-sm font-sans text-paqui-muted">&larr; Anterior</span>
  )}

  <span class="text-[11px] font-sans text-paqui-muted tracking-wider uppercase">
    {currentPage} de {totalPages}
  </span>

  {nextUrl ? (
    <a href={nextUrl} class="text-sm font-sans font-medium text-paqui-body hover:text-paqui-red transition-colors">
      Siguiente &rarr;
    </a>
  ) : (
    <span class="text-sm font-sans text-paqui-muted">Siguiente &rarr;</span>
  )}
</nav>
