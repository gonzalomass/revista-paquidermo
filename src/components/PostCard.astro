---
interface Props {
  title: string;
  date: string;
  author: string;
  authorName?: string;
  slug: string;
  excerpt?: string;
  categories?: string[];
  columna?: string;
  seccion?: string;
}

import { slugify } from '../lib/slugify';

const { title, date, author, authorName, slug, excerpt, categories = [], columna, seccion } = Astro.props;
const displayAuthor = authorName || author;

const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('es-CR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="post-card py-6 border-t border-paqui-rule/40 group relative">
  {categories.length > 0 && (
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2.5">
      <svg class="w-3 h-3 text-paqui-red shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="5" height="5" rx="0.5"/><rect x="9" y="2" width="5" height="5" rx="0.5"/><rect x="2" y="9" width="5" height="5" rx="0.5"/><rect x="9" y="9" width="5" height="5" rx="0.5"/></svg>
      {categories.map((cat) => (
        <a
          href={`/categoria/${cat.toLowerCase().replace(/\s+/g, '-')}`}
          class="text-[10px] font-sans font-bold uppercase tracking-[0.15em] text-paqui-red hover:text-paqui-dark transition-colors"
        >
          - {cat} -
        </a>
      ))}
    </div>
  )}

  <a href={`/${slug}`} class="block">
    <h2 class="font-display text-[1.35rem] md:text-[1.75rem] font-bold leading-snug text-paqui-dark group-hover:text-paqui-red transition-colors duration-300">
      {title}
    </h2>
  </a>

  <div class="mt-2.5 flex items-center gap-x-3 text-[13px] font-sans">
    {author && (
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-paqui-red shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.5 14v-1.5a2.5 2.5 0 00-2.5-2.5H6a2.5 2.5 0 00-2.5 2.5V14"/><circle cx="8" cy="5" r="2.5"/></svg>
        <a href={`/autor/${author}`} class="text-paqui-body font-bold text-paqui-red hover:text-paqui-dark transition-colors">
          {displayAuthor}
        </a>
      </span>
    )}
    <span class="inline-flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="12" height="12" rx="1"/><path d="M2 6h12M5 2v4M11 2v4"/></svg>
      <time datetime={date} class="text-paqui-muted">{formattedDate}</time>
    </span>
    {columna && (
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v12M8 2v12M13 2v12"/></svg>
        <a href={`/columna/${slugify(columna)}`} class="text-paqui-gray hover:text-paqui-red transition-colors">{columna}</a>
      </span>
    )}
    {seccion && (
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-paqui-muted shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4h12M2 8h12M2 12h12"/></svg>
        <a href={`/seccion/${slugify(seccion)}`} class="text-paqui-gray hover:text-paqui-red transition-colors">{seccion}</a>
      </span>
    )}
  </div>

  {excerpt && (
    <div class="mt-3.5">
      <p class="text-base md:text-lg font-serif text-paqui-black leading-relaxed line-clamp-2">{excerpt}</p>
      <a href={`/${slug}`} class="inline-block mt-2 text-paqui-red text-base md:text-md font-sans tracking-wide hover:underline">
        ... la hablada &rarr;
      </a>
    </div>
  )}
</article>
