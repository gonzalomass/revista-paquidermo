---
interface Props {
  title: string;
  date: string;
  author: string;
  authorName?: string;
  slug: string;
  excerpt?: string;
  categories?: string[];
}

const { title, date, author, authorName, slug, excerpt, categories = [] } = Astro.props;
const displayAuthor = authorName || author;

const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('es-CR', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});
---

<article class="group border-l-4 border-transparent hover:border-paqui-red pl-5 py-2 transition-all">
  <div class="flex flex-wrap gap-2 mb-2">
    {categories.map((cat) => (
      <a
        href={`/categoria/${cat.toLowerCase().replace(/\s+/g, '-')}`}
        class="text-xs font-semibold uppercase tracking-wider bg-paqui-red text-white px-2 py-0.5 hover:bg-paqui-dark transition-colors"
      >
        {cat}
      </a>
    ))}
  </div>

  <a href={`/${slug}`} class="block">
    <h2 class="font-display text-lg md:text-2xl font-bold uppercase leading-tight group-hover:text-paqui-red transition-colors">
      {title}
    </h2>
  </a>

  <div class="mt-2 text-sm text-paqui-gray flex items-center gap-1.5">
    {author && (
      <a href={`/autor/${author}`} class="font-semibold text-paqui-red hover:underline">
        {displayAuthor}
      </a>
    )}
    <span>&middot;</span>
    <time datetime={date}>{formattedDate}</time>
  </div>

  {excerpt && (
    <p class="mt-3 text-paqui-gray leading-relaxed line-clamp-3">
      {excerpt}
      <a href={`/${slug}`} class="text-paqui-red font-semibold hover:underline ml-1">
        ...la hablada &rarr;
      </a>
    </p>
  )}
</article>
